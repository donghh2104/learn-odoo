<odoo>
	<record id="house_view_form" model="ir.ui.view">
		<field name="name">house.form</field>
		<field name="model">house</field>
		<field name="arch" type="xml">
			<form string="House">
				<sheet>
					<group>
						<group>
							<field name="name" />
							<field name="price" />
						</group>
						<group title="Owner Information">
							<field name="people_id" />
							<field name="owner_gender" />
						</group> 
					</group>
					<group string="Inhabitants">
						<field name="people_ids" widget="many2many_tags"/>
					</group>
				</sheet>
			</form>
		</field>
	</record>

	<record id="house_action" model="ir.actions.act_window">
		<field name="name">House</field>
		<field name="type">ir.actions.act_window</field>
		<field name="res_model">house</field>
	</record>

	<record id="house_view_tree" model="ir.ui.view">
		<field name="name">house.tree</field>
		<field name="model">house</field>
		<field name="arch" type="xml">
			<tree>
				<field name="name" />
				<field name="people_id" />
				<field name="price" />
			</tree>
		</field>
	</record>

	<menuitem id="menu_house" name="Many2xxx Field" parent="menu_field" action='house_action' />
</odoo>
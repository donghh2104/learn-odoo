<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_estate_property_followup" model="ir.cron">
        <field name="name">Estate - Follow-up stale properties</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="state">code</field>
        <field name="code">model._cron_schedule_stale_property_activities()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>

    <record id="ir_cron_estate_offer_expiry" model="ir.cron">
        <field name="name">Estate - Notify expiring offers</field>
        <field name="model_id" ref="model_estate_property_offer"/>
        <field name="state">code</field>
        <field name="code">model._cron_notify_expiring_offers()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="numbercall">-1</field>
        <field name="active">True</field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_real_estate" model="ir.module.category">
        <field name="name">Quản lý Bất động sản</field>
        <field name="sequence">10</field>
    </record>

    <record id="group_estate_user" model="res.groups">
        <field name="name">Nhân viên (Agent)</field>
        <field name="category_id" ref="module_category_real_estate"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_estate_auditor" model="res.groups">
        <field name="name">Kiểm toán viên (Auditor)</field>
        <field name="category_id" ref="module_category_real_estate"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_estate_manager" model="res.groups">
        <field name="name">Quản lý (Manager)</field>
        <field name="category_id" ref="module_category_real_estate"/>
        <field name="implied_ids" eval="[(4, ref('group_estate_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <record id="estate_property_rule_personal" model="ir.rule">
        <field name="name">BĐS cá nhân phụ trách</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">['|', ('salesperson_id', '=', user.id), ('salesperson_id', '=', False)]</field>
        <field name="groups" eval="[(4, ref('group_estate_user'))]"/>
    </record>

    <record id="estate_property_rule_all" model="ir.rule">
        <field name="name">Tất cả BĐS công ty</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_manager'))]"/>
    </record>

    <record id="estate_property_rule_auditor_read_all" model="ir.rule">
        <field name="name">Auditor xem toàn bộ BĐS</field>
        <field name="model_id" ref="model_estate_property"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_estate_auditor'))]"/>
    </record>
</odoo>

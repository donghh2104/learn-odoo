<odoo>
    <record id="cetizen_view_form" model="ir.ui.view">
        <field name="name">cetizen.form</field>
        <field name="model">cetizen</field>
        <field name="arch" type="xml">
            <form string="Citizen">
                <sheet>
                    <group>
                        <!-- Trường name này được kế thừa từ model People -->
                        <field name="name" placeholder="Nhập tên công dân (tự động tạo bản ghi People)"/>
                        <field name="passport_id" />
                    </group>
                    <group>
                        <field name="ref_model" />
                        <field name="ref_id" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="cetizen_action" model="ir.actions.act_window">
        <field name="name">Citizen</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">cetizen</field>
    </record>

    <menuitem id="menu_cetizen" name="One to One Field" parent="menu_field" action='cetizen_action' />
</odoo>

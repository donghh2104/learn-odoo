<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_property_details">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="property">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center mt32">HỒ SƠ CHI TIẾT BẤT ĐỘNG SẢN</h2>
                        <h3 class="text-primary mt16">
                            <span t-field="property.name"/>
                        </h3>
                        
                        <div class="row mt32 mb32">
                            <div class="col-6">
                                <strong>Loại nhà: </strong> <span t-field="property.property_type_id.name"/><br/>
                                <strong>Giá mong muốn: </strong> <span t-field="property.expected_price" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/><br/>
                                <strong>Giá đề nghị tốt nhất: </strong> <span t-field="property.best_price" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/>
                            </div>
                            <div class="col-6">
                                <strong>Mã bưu điện: </strong> <span t-field="property.postcode"/><br/>
                                <strong>Trạng thái: </strong> <span t-field="property.state"/><br/>
                                <strong>Nhân viên phụ trách: </strong> <span t-field="property.salesperson_id.name"/>
                            </div>
                        </div>

                        <h4 class="mt32" t-if="property.offer_ids">Danh sách các lời đề nghị mua</h4>
                        <table class="table table-sm o_main_table" t-if="property.offer_ids">
                            <thead>
                                <tr class="bg-light">
                                    <th>Đối tác/Khách hàng</th>
                                    <th>Giá đề nghị</th>
                                    <th>Hạn chót</th>
                                    <th>Trạng thái</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr t-foreach="property.offer_ids" t-as="offer">
                                    <td><span t-field="offer.partner_id.name"/></td>
                                    <td><span t-field="offer.price" t-options='{"widget": "monetary", "display_currency": res_company.currency_id}'/></td>
                                    <td><span t-field="offer.date_deadline"/></td>
                                    <td><span t-field="offer.status"/></td>
                                </tr>
                            </tbody>
                        </table>
                        
                        <div class="mt64" t-if="property.description">
                            <strong>Mô tả thêm:</strong>
                            <p t-field="property.description"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>

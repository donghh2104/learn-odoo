<odoo>
    <!-- Giao diện danh sách (Tree View) -->
    <record id="player_view_tree" model="ir.ui.view">
        <field name="name">player.tree</field>
        <field name="model">player</field>
        <field name="arch" type="xml">
            <tree string="Players">
                <field name="name"/>
                <field name="country"/>
                <field name="position"/>
            </tree>
        </field>
    </record>

    <!-- Giao diện chi tiết (Form View) -->
    <record id="people_view_form" model="ir.ui.view">
        <field name="name">player.form</field>
        <field name="model">player</field>
        <field name="arch" type="xml">
            <form string="Player">
                <sheet>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="country" />
                            <field name="gender" />
                        </group>
                        <group>
                            <field name="height" />
                            <field name="weight" />
                            <field name="date_of_birth" />
                            <field name="position" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Hành động (Action) -->
    <record id="player_action" model="ir.actions.act_window">
        <field name="name">Player</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">player</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="player_menu_root" name="Football" groups="base.group_user"/>
    <menuitem id="player_menu_category" name="People" parent="player_menu_root" groups="base.group_user"/>
    <menuitem id="player_menu_action" name="Players" parent="player_menu_category" action='player_action' groups="base.group_user"/>
</odoo>
